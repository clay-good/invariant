# Rust build artifacts
/target/
**/target/
fuzz/target/
fuzz/Cargo.lock
**/Cargo.lock.bak

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
venv/
.venv/
*.egg-info/

# Lean 4
formal/build/
formal/lake-packages/
formal/.lake/

# Claude Code / Codelicious (local-only)
.claude/
.codelicious/

# Secrets (never commit)
.env
.env.*
keys.json
*.pem
*.key

# Runtime artifacts
*.jsonl
# ... but test fixtures must always be committed.
!**/tests/fixtures/*.jsonl
safe-stop.json
results/

# Fuzzing artifacts
fuzz/artifacts/
fuzz/corpus/*/
!fuzz/corpus/*/.gitkeep

# Release / packaging
dist/
*.cdx.json
*.tar.gz

# Editor / tooling backups
*.bak
*.orig

# Downloaded CI log dumps (e.g. `gh run download` extracts to a folder
# named `logs_<run-id>`, or a single concatenated `log.log`)
logs_*/
log.log
